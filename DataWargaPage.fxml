<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="1000" prefHeight="650"
            style="-fx-background-color: #FAF3E0;">

    <!-- SIDEBAR sama seperti Dashboard -->
    <left>
        <VBox prefWidth="200" style="-fx-background-color: #3E1F0D;">
            <VBox style="-fx-background-color: #2A1408; -fx-padding: 18 14 14 14;" spacing="4">
                <Label text="🕌 Antrian Qurban" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #FAF3E0;"/>
                <Label text="PMI RPL 2026" style="-fx-font-size: 10px; -fx-text-fill: #7A4520;"/>
            </VBox>
            <Button text="  📊  Dashboard" maxWidth="Infinity" onAction="#goDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            <Button text="  👤  Data Warga" maxWidth="Infinity"
                    style="-fx-background-color: #5C2E0E; -fx-text-fill: #FAF3E0; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-border-color: #D4B870; -fx-border-width: 0 0 0 3;"/>
            <Button text="  📋  Antrian" maxWidth="Infinity" onAction="#goAntrian"
                    style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            <Button text="  🔊  Panggil Antrian" maxWidth="Infinity" onAction="#goPanggil"
                    style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            <Button text="  📍  Wilayah" maxWidth="Infinity" onAction="#goWilayah"
                    style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox style="-fx-background-color: #2A1408; -fx-padding: 12 14;" spacing="8" alignment="CENTER_LEFT">
                <Label text="👤" style="-fx-font-size: 18px;"/>
                <Label text="User Panitia" style="-fx-font-size: 11px; -fx-text-fill: #E0C98A;"/>
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="14" style="-fx-background-color: #FAF3E0;">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="2">
                    <Label text="Data Warga" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;"/>
                    <Label text="Kelola data warga penerima qurban" style="-fx-font-size: 11px; -fx-text-fill: #8B5E3C;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnTambahWarga" text="+ Tambah Warga" onAction="#handleTambah"
                        style="-fx-background-color: #5C2E0E; -fx-text-fill: #FAF3E0; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 6 14; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button fx:id="btnEditWarga" text="✏ Edit" onAction="#handleEdit"
                        style="-fx-background-color: #F0E0B6; -fx-border-color: #D4B870; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12px; -fx-padding: 6 14; -fx-cursor: hand;"/>
                <Button fx:id="btnHapusWarga" text="🗑 Hapus" onAction="#handleHapus"
                        style="-fx-background-color: #FCE4E4; -fx-border-color: #E57373; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12px; -fx-padding: 6 14; -fx-cursor: hand;"/>
            </HBox>

            <Separator style="-fx-background-color: #E0C98A;"/>

            <TableView fx:id="tabelWarga" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #F0E0B6; -fx-border-color: #D4B870; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colNo"       text="No"       prefWidth="50"/>
                    <TableColumn fx:id="colNik"      text="NIK"      prefWidth="160"/>
                    <TableColumn fx:id="colNama"     text="Nama Warga" prefWidth="200"/>
                    <TableColumn fx:id="colHp"       text="No HP"    prefWidth="130"/>
                    <TableColumn fx:id="colWilayah"  text="Wilayah"  prefWidth="120"/>
                </columns>
            </TableView>

        </VBox>
    </center>
</BorderPane>
