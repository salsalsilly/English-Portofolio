<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="1000" prefHeight="650"
            style="-fx-background-color: #FAF3E0;">

    <!-- SIDEBAR KIRI -->
    <left>
        <VBox prefWidth="200" spacing="0"
              style="-fx-background-color: #3E1F0D;">
            <padding><Insets top="0"/></padding>

            <!-- Header Sidebar -->
            <VBox style="-fx-background-color: #2A1408; -fx-padding: 18 14 14 14;" spacing="4">
                <Label text="🕌 Antrian Qurban"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #FAF3E0;"/>
                <Label text="PMI RPL 2026"
                       style="-fx-font-size: 10px; -fx-text-fill: #7A4520;"/>
            </VBox>

            <!-- Menu -->
            <Button text="  📊  Dashboard" maxWidth="Infinity"
                    style="-fx-background-color: #5C2E0E; -fx-text-fill: #FAF3E0;
                           -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT;
                           -fx-border-color: #D4B870; -fx-border-width: 0 0 0 3;"/>
            <Button text="  👤  Data Warga" maxWidth="Infinity" onAction="#goDataWarga"
                    style="-fx-background-color: transparent; -fx-text-fill: #C4956A;
                           -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            <Button text="  📋  Antrian" maxWidth="Infinity" onAction="#goAntrian"
                    style="-fx-background-color: transparent; -fx-text-fill: #C4956A;
                           -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            <Button text="  🔊  Panggil Antrian" maxWidth="Infinity" onAction="#goPanggil"
                    style="-fx-background-color: transparent; -fx-text-fill: #C4956A;
                           -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            <Button text="  📍  Wilayah" maxWidth="Infinity" onAction="#goWilayah"
                    style="-fx-background-color: transparent; -fx-text-fill: #C4956A;
                           -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- User Info -->
            <HBox style="-fx-background-color: #2A1408; -fx-padding: 12 14;" spacing="8" alignment="CENTER_LEFT">
                <Label text="👤" style="-fx-font-size: 18px;"/>
                <Label text="User Panitia"
                       style="-fx-font-size: 11px; -fx-text-fill: #E0C98A;"/>
            </HBox>
        </VBox>
    </left>

    <!-- KONTEN UTAMA -->
    <center>
        <VBox spacing="16" style="-fx-background-color: #FAF3E0;">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <!-- Topbar -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="2">
                    <Label text="Dashboard"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;"/>
                    <Label text="Senin, 20 April 2026 — Idul Adha 1447 H"
                           style="-fx-font-size: 11px; -fx-text-fill: #8B5E3C;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🖨 Cetak"
                        style="-fx-background-color: white; -fx-border-color: #D4B870;
                               -fx-border-radius: 6; -fx-background-radius: 6;
                               -fx-font-size: 12px; -fx-padding: 6 14; -fx-cursor: hand;"/>
                <Button text="+ Tambah Antrian" onAction="#handleTambahAntrian"
                        style="-fx-background-color: #5C2E0E; -fx-text-fill: #FAF3E0;
                               -fx-font-size: 12px; -fx-font-weight: bold;
                               -fx-padding: 6 14; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>

            <Separator style="-fx-background-color: #E0C98A;"/>

            <!-- Stat Cards -->
            <HBox spacing="12">
                <!-- Card 1 -->
                <VBox style="-fx-background-color: #F0E0B6; -fx-background-radius: 10;
                             -fx-border-color: #D4B870; -fx-border-radius: 10; -fx-padding: 14;"
                      spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="👥 Total Warga"
                           style="-fx-font-size: 11px; -fx-text-fill: #8B5E3C;"/>
                    <Label text="248"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;"/>
                    <Label text="terdaftar"
                           style="-fx-font-size: 10px; -fx-text-fill: #A0622E;"/>
                </VBox>
                <!-- Card 2 -->
                <VBox style="-fx-background-color: #FFF9C4; -fx-background-radius: 10;
                             -fx-border-color: #F9A825; -fx-border-radius: 10; -fx-padding: 14;"
                      spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="⏳ Menunggu"
                           style="-fx-font-size: 11px; -fx-text-fill: #F57F17;"/>
                    <Label text="42"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;"/>
                    <Label text="antrian"
                           style="-fx-font-size: 10px; -fx-text-fill: #A0622E;"/>
                </VBox>
                <!-- Card 3 -->
                <VBox style="-fx-background-color: #BBDEFB; -fx-background-radius: 10;
                             -fx-border-color: #1565C0; -fx-border-radius: 10; -fx-padding: 14;"
                      spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="🔊 Dipanggil"
                           style="-fx-font-size: 11px; -fx-text-fill: #0D47A1;"/>
                    <Label text="3"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;"/>
                    <Label text="sedang proses"
                           style="-fx-font-size: 10px; -fx-text-fill: #A0622E;"/>
                </VBox>
            </HBox>

            <!-- Tabel Antrian Terbaru -->
            <Label text="Antrian Terbaru"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;"/>

            <TableView fx:id="tabelAntrian" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #F0E0B6;
                              -fx-border-color: #D4B870;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colNomor" text="No Antrian" prefWidth="100"/>
                    <TableColumn fx:id="colNama"  text="Nama Warga" prefWidth="200"/>
                    <TableColumn fx:id="colWilayah" text="Wilayah" prefWidth="130"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="110"/>
                    <TableColumn fx:id="colWaktu" text="Waktu Daftar" prefWidth="140"/>
                </columns>
            </TableView>

        </VBox>
    </center>

</BorderPane>
