<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="1000" prefHeight="650"
            style="-fx-background-color: #FAF3E0;">
    <left>
        <VBox prefWidth="200" style="-fx-background-color: #3E1F0D;">
            <VBox style="-fx-background-color: #2A1408; -fx-padding: 18 14 14 14;" spacing="4">
                <Label text="🕌 Antrian Qurban" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #FAF3E0;"/>
                <Label text="PMI RPL 2026" style="-fx-font-size: 10px; -fx-text-fill: #7A4520;"/>
            </VBox>
            <Button text="  📊  Dashboard"       maxWidth="Infinity" onAction="#goDashboard" style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            <Button text="  👤  Data Warga"      maxWidth="Infinity" onAction="#goDataWarga" style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            <Button text="  📋  Antrian"         maxWidth="Infinity" onAction="#goAntrian"  style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            <Button text="  🔊  Panggil Antrian"  maxWidth="Infinity" style="-fx-background-color: #5C2E0E; -fx-text-fill: #FAF3E0; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-border-color: #D4B870; -fx-border-width: 0 0 0 3;"/>
            <Button text="  📍  Wilayah"         maxWidth="Infinity" onAction="#goWilayah"  style="-fx-background-color: transparent; -fx-text-fill: #C4956A; -fx-font-size: 12px; -fx-padding: 12 14; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox style="-fx-background-color: #2A1408; -fx-padding: 12 14;" spacing="8" alignment="CENTER_LEFT">
                <Label text="👤" style="-fx-font-size: 18px;"/>
                <Label text="User Panitia" style="-fx-font-size: 11px; -fx-text-fill: #E0C98A;"/>
            </HBox>
        </VBox>
    </left>
    <center>
        <VBox spacing="16" style="-fx-background-color: #FAF3E0;">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
            <Label text="Panggil Antrian" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;"/>
            <Separator style="-fx-background-color: #E0C98A;"/>

            <HBox spacing="16" VBox.vgrow="ALWAYS">
                <!-- Panel Sedang Dipanggil -->
                <VBox spacing="14" alignment="CENTER"
                      style="-fx-background-color: #F0E0B6; -fx-background-radius: 12;
                             -fx-border-color: #D4B870; -fx-border-radius: 12; -fx-padding: 24;"
                      HBox.hgrow="ALWAYS">
                    <Label text="SEDANG DIPANGGIL"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8B5E3C;"/>
                    <!-- Kotak nomor besar -->
                    <StackPane style="-fx-background-color: #5C2E0E; -fx-background-radius: 14;"
                               prefWidth="160" prefHeight="160">
                        <VBox alignment="CENTER" spacing="4">
                            <Label text="Nomor Antrian"
                                   style="-fx-font-size: 11px; -fx-text-fill: #E0C98A;"/>
                            <Label fx:id="lblNomor" text="007"
                                   style="-fx-font-size: 56px; -fx-font-weight: bold; -fx-text-fill: #FAF3E0;"/>
                        </VBox>
                    </StackPane>
                    <Label fx:id="lblNamaWarga" text="Ani Wijayanti"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;"/>
                    <Label fx:id="lblWilayah" text="RT 02/RW 02 — 09:00 WIB"
                           style="-fx-font-size: 12px; -fx-text-fill: #8B5E3C;"/>
                    <HBox spacing="10" alignment="CENTER">
                        <Button text="Lewati" onAction="#handleLewati"
                                style="-fx-background-color: white; -fx-border-color: #D4B870; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 20; -fx-cursor: hand;"/>
                        <Button text="✓ Selesai" onAction="#handleSelesai"
                                style="-fx-background-color: #5C2E0E; -fx-text-fill: #FAF3E0; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 20; -fx-cursor: hand;"/>
                    </HBox>
                    <Button text="🔊 Panggil Berikutnya" onAction="#handlePanggil"
                            maxWidth="Infinity"
                            style="-fx-background-color: #3E1F0D; -fx-text-fill: #FAF3E0; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 10; -fx-cursor: hand;"/>
                </VBox>

                <!-- Tabel Menunggu -->
                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Antrian Menunggu"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3E1F0D;"/>
                    <TableView fx:id="tabelMenunggu" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #F0E0B6; -fx-border-color: #D4B870; -fx-border-radius: 8; -fx-background-radius: 8;">
                        <columns>
                            <TableColumn fx:id="colNomor" text="No" prefWidth="70"/>
                            <TableColumn fx:id="colNama"  text="Nama Warga" prefWidth="160"/>
                            <TableColumn fx:id="colWil"   text="Wilayah" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
