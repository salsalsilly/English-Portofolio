<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           prefWidth="900" prefHeight="600"
           style="-fx-background-color: #3E1F0D;">

    <VBox alignment="CENTER" spacing="20">
        <padding><Insets top="60" bottom="60" left="40" right="40"/></padding>

        <!-- Logo / Ikon -->
        <Label text="🕌"
               style="-fx-font-size: 56px;"/>

        <!-- Nama Organisasi -->
        <Label text="DKM AL-FALAAAH"
               style="-fx-font-size: 14px;
                      -fx-text-fill: #E0C98A;
                      -fx-font-weight: bold;
                      -fx-letter-spacing: 3px;"/>

        <!-- Judul Utama -->
        <Label text="ANTRIAN PENGAMBILAN"
               style="-fx-font-size: 32px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #FAF3E0;"/>
        <Label text="DAGING QURBAN"
               style="-fx-font-size: 32px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #FAF3E0;"/>

        <!-- Ayat -->
        <Label text="فَضْلٌ ارْزُكَ وَانْحَرْ"
               style="-fx-font-size: 18px;
                      -fx-text-fill: #D4B870;
                      -fx-font-style: italic;"/>
        <Label text="Maka dirikanlah shalat karena Tuhanmu, dan berkurbanlah"
               style="-fx-font-size: 12px;
                      -fx-text-fill: #A0622E;"/>

        <Region prefHeight="20"/>

        <!-- Tombol Masuk -->
        <Button fx:id="btnMasuk" text="MASUK →"
                onAction="#handleMasuk"
                style="-fx-background-color: #F0E0B6;
                       -fx-text-fill: #3E1F0D;
                       -fx-font-weight: bold;
                       -fx-font-size: 14px;
                       -fx-padding: 12 40 12 40;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;"/>

        <!-- Footer -->
        <Region prefHeight="20"/>
        <Label text="© 2026 Sistem Antrian Qurban · Politeknik Mardira Indonesia"
               style="-fx-font-size: 10px; -fx-text-fill: #7A4520;"/>
    </VBox>

</StackPane>
